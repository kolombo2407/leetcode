   "source": [
    "def twoSum(nums: list, target: int) -> list:\n",
    "    for i in range(len(nums)):\n",
    "        for j in range(i+1, len(nums)):\n",
    "            if nums[j] == target - nums[i]:\n",
    "                return [i,j]"
   ]
  },
  {
